---

<Layout title="La Mia Luna FCI - Hodowla Lagotto Romagnolo">
  {/* Hero Section */}
  <DogCard
    name="II Granaio Dei Malatesta Mina"
    image="/images/mina/mina-hero.webp"
    description="Po dwóch latach z Monday postanowiliśmy znaleźć dla niego przyjaciółkę. Po długiej drodze trafiła do nas Mina, która jest Włoszką. Mina wniosła do naszej hodowli cenne włoskie linie krwi i niesamowity, radosny charakter."
    characteristics="Cudowna i uśmiechnięta przez cały czas"
    achievements="Grand Champion Polski, Międzynarodowy Champion Piękności C.I.B i wiele więcej..."
  />

  {/* Pedigree Section */}
  <section class="mx-auto mb-16 max-w-6xl">
    <PedigreeTree
      dog={mondayPedigree.dog}
      parents={mondayPedigree.parents}
      grandparents={mondayPedigree.grandparents}
    />
  </section>

  {/* Achievements Section */}
  <section class="mx-auto mb-16 max-w-6xl text-center">
    <HeadingTwo title="Osiągnięcia Wystawowe" />
    <CarouselOfCertificates client:load certificates={certificates} />
    <CarouselOfImages client:load images={images} />
  </section>

  {/* Offspring Section */}
  <section class="mx-auto max-w-6xl text-center">
    <HeadingTwo title="Potomstwo Monday'a" />
    <div class="grid gap-6 md:grid-cols-3">
      {offspring.map((pup) => <OffspringCard {...pup} />)}
    </div>
  </section>
</Layout>
