---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link
      href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700&family=Playfair+Display:wght@700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body
    class="flex min-h-screen flex-col bg-linear-to-br from-orange-50 via-rose-50 to-pink-50 font-sans text-orange-900"
  >
    <Header />

    <main class="container mx-auto my-16 max-w-[1280px] grow px-4">
      <slot />
    </main>

    <Footer />
  </body>
</html>
