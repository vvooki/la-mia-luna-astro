---
import { CalendarHeart } from 'lucide-react';
import ImageWithFallback from './ImageWithFallback.astro';
import HeadingThree from './typography/HeadingThree.astro';
import GenderBadge from './GenderBadge.astro';

interface Props {
  name: string;
  birthDate: string;
  description: string;
  imageUrl: string;
  gender: 'male' | 'female';
}

const { name, gender, birthDate, description, imageUrl } = Astro.props;
---

<div
  class="overflow-hidden rounded-xl bg-white shadow-md transition-all hover:-translate-y-1 hover:shadow-xl"
>
  <div class="aspect-square overflow-hidden">
    <ImageWithFallback
      src={imageUrl}
      alt={description}
      class="h-full w-full object-cover transition-transform duration-500 hover:scale-110"
    />
  </div>
  <div class="p-5">
    <div class="flex flex-col justify-between gap-2 md:flex-row">
      <div class="flex flex-col">
        <span class="font-bold">{name}</span>
        <span class="flex items-center gap-2 text-xs">
          <CalendarHeart size={14} /> Urodzony: {birthDate}
        </span>
      </div>
      <GenderBadge variant={gender} />
    </div>
    <p class="mt-4 mb-3 text-sm text-orange-700">{description}</p>
  </div>
</div>
