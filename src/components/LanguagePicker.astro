---
import { languages } from '../i18n/i18n';
---

<div class="my-6 flex justify-center gap-4">
  {
    Object.entries(languages).map(([code, label]) => (
      <a
        href={code === 'pl' ? '/pl' : `/${code}/`}
        class="rounded border border-indigo-500 px-3 py-1 transition-colors hover:bg-indigo-500 hover:text-white dark:text-white"
      >
        {label}
      </a>
    ))
  }
</div>
